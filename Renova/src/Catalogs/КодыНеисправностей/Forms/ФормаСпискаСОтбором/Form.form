          <localValue>
            <content>
              <key>ru</key>
              <value>Виды продукции</value>
            </content>
          </localValue>
        </title>
        <valueType>
          <types>CatalogRef.ВидыПродукции</types>
        </valueType>
        <values xsi:type="core:UndefinedValue"/>
        <useRestriction>true</useRestriction>
      </parameters>
    </extInfo>
