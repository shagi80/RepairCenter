    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникКодыНеисправностей.ЭтоГруппа КАК ЭтоГруппа,
	СправочникКодыНеисправностей.Наименование КАК Наименование,
	СправочникКодыНеисправностей.СимвольныйКод КАК СимвольныйКод,
	СправочникКодыНеисправностей.ВидПродукции.Ссылка КАК ВидПродукции,
	ВидыПродукции.Ссылка КАК Ссылка,
	СправочникКодыНеисправностей.Родитель КАК Родитель,
	СправочникКодыНеисправностей.ЭтоГруппа КАК ЭтоГруппа1
ИЗ
	Справочник.КодыНеисправностей КАК СправочникКодыНеисправностей
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыПродукции КАК ВидыПродукции
		ПО СправочникКодыНеисправностей.ВидПродукции.Ссылка = ВидыПродукции.Ссылка
ГДЕ
	(СправочникКодыНеисправностей.ВидПродукции = &amp;ВидыПродукции
			ИЛИ СправочникКодыНеисправностей.ВидПродукции.Ссылка ЕСТЬ NULL)
	И НЕ СправочникКодыНеисправностей.ЭтоГруппа</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Ссылка</dataPath>
        <field>Ссылка</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ЭтоГруппа</dataPath>
        <field>ЭтоГруппа</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Наименование</dataPath>
        <field>Наименование</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>СимвольныйКод</dataPath>
        <field>СимвольныйКод</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ВидПродукции</dataPath>
        <field>ВидПродукции</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Родитель</dataPath>
        <field>Родитель</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ЭтоГруппа1</dataPath>
        <field>ЭтоГруппа1</field>
        <title>
          <localValue>
            <content>
              <key>ru</key>
              <value>Это группа1</value>
            </content>
          </localValue>
        </title>
      </fields>
      <parameters>
        <name>ВидыПродукции</name>
