    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Ремонт.Номер КАК Номер,
	Ремонт.Дата КАК Дата,
	Ремонт.IDСайта КАК IDСайта,
	(ВЫРАЗИТЬ(ОтчетОРемонтах.СервисныйЦентр.Наименование КАК СТРОКА(150))) + &amp;Предлог + (ВЫРАЗИТЬ(ОтчетОРемонтах.ОтчетныйПериод КАК СТРОКА(150))) КАК Отчет,
	Ремонт.ВидРемонта КАК ВидРемонта,
	Ремонт.Клиент КАК Клиент,
	Ремонт.МодельПродукции КАК МодельПродукции,
	Ремонт.ДатаНачалаРемонта КАК ДатаНачалаРемонта,
	Ремонт.ОписаниеНеисправности КАК ОписаниеНеисправности,
	Ремонт.Примечание КАК Примечание
ИЗ
	Документ.Ремонт КАК Ремонт
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтчетОРемонтах КАК ОтчетОРемонтах
		ПО (Ремонт.КодОтчета = ОтчетОРемонтах.IDСайта)</queryText>
      <mainTable>Document.Ремонт</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Отчет</dataPath>
        <field>Отчет</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>МодельПродукции</dataPath>
        <field>МодельПродукции</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ОписаниеНеисправности</dataPath>
        <field>ОписаниеНеисправности</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ДатаНачалаРемонта</dataPath>
        <field>ДатаНачалаРемонта</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Примечание</dataPath>
        <field>Примечание</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>IDСайта</dataPath>
        <field>IDСайта</field>
