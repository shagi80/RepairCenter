#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОбработчикиСобытий  

	
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Если Не ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
		НачалоПериода = НачалоМесяца(ТекущаяУниверсальнаяДата());
		КонецПериода = НачалоПериода;
	КонецЕсли;
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
    	Возврат;
	КонецЕсли;
		
   	// Получаем списко видов продукции без повторений
   	ТаблицаВидовПродукции = Товары.Выгрузить( , "ВидПродукции");
   	ТаблицаВидовПродукции.Свернуть("ВидПродукции");
   	МассивВидовПродукции = ТаблицаВидовПродукции.ВыгрузитьКолонку("ВидПродукции");
   	СписокВидовПродукции = СтрСоединить(МассивВидовПродукции, ", ");

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)

    // Получаем соответствие запрещенных комбинаций (ключ -> дата более позднего документа)
    ЗапрещенныеКомбинации = ПолучитьЗапрещенныеКомбинации();

    // Начинаем формирование движений
    Движения.Продажи.Записывать = Истина;
	Движения.Продажи.Записать();

    КоличествоЗапрещено = 0;
    КоличествоПерезаписано = 0;

    Для Каждого ТекСтрокаТовары Из Товары Цикл

        // Пропускаем строки с незаполненными обязательными реквизитами
        Если Не ЗначениеЗаполнено(ТекСтрокаТовары.Номенклатура) Или
           Не ЗначениеЗаполнено(ТекСтрокаТовары.Количество) Тогда
            Продолжить;
        КонецЕсли;
		
		Если ЗапрещенныеКомбинации.Количество() > 0 Тогда
			// Формируем ключ для проверки (единый формат для обеих сторон)
			Ключ = Строка(ТекСтрокаТовары.Номенклатура) + "|" + Формат(ТекСтрокаТовары.МесяцПродаж, "ДФ=yyyyMMdd");
		КонецЕсли;
		
        // Проверяем, есть ли более поздняя запись в регистре
        Если ЗапрещенныеКомбинации.Получить(Ключ) <> Неопределено Тогда
            Текст = """Строка по модели " + ТекСтрокаТовары.Номенклатура +
                      " за месяц " + Формат(ТекСтрокаТовары.МесяцПродаж, "ДФ='MMMM yyyy';") +
                      " НЕ БУДЕТ ЗАПИСАНА, так как имеются более поздние данные (документ от " +
                      Формат(ЗапрещенныеКомбинации[Ключ], "Д") + ").""";
            Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = Текст;
			Сообщение.Сообщить();  
            КоличествоЗапрещено = КоличествоЗапрещено + 1;
            Продолжить;
        КонецЕсли;

        // Создаём движение
		Движение = Движения.Продажи.Добавить();
		Движение.Период = Дата;
		Движение.МесяцПродаж = ТекСтрокаТовары.МесяцПродаж; 
		Движение.ВидПродукции = ТекСтрокаТовары.ВидПродукции;
		Движение.МоделиПродукции = ТекСтрокаТовары.Номенклатура;
		Движение.Фирма = Фирма;    
		Движение.КоличествоПродано = ТекСтрокаТовары.Количество;

        КоличествоПерезаписано = КоличествоПерезаписано + 1;

    КонецЦикла;

    // Выводим итоговые сообщения
    Если КоличествоЗапрещено > 0 Тогда
        ТекстПропущено = "Внимание! Было пропущено " + КоличествоЗапрещено + " строк(и) из-за наличия более поздних записей.";
        Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = ТекстПропущено;
		Сообщение.Сообщить();
    КонецЕсли;

    Если КоличествоПерезаписано > 0 Тогда
    	Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Записано " + КоличествоПерезаписано + " строк(и). Старые данные (если были) перезаписаны.";
		Сообщение.Сообщить();
    Иначе
        Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = "Нет данных для проведения документа!";
		Сообщение.Сообщить();
		Отказ = Истина;
    КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 


#Область СлужебныеПроцедурыИФункции 

Функция ПолучитьЗапрещенныеКомбинации() Экспорт 
	
  	МассивНоменклатуры = Товары.ВыгрузитьКолонку("Номенклатура");
	МассивМесяцев = Товары.ВыгрузитьКолонку("МесяцПродаж");

    // Запрос к регистру для получения максимальной даты документа по каждой комбинации
    Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Продажи.МоделиПродукции КАК МоделиПродукции,
	               |	Продажи.МесяцПродаж КАК МесяцПродаж,
	               |	МАКСИМУМ(Продажи.Период) КАК Период
	               |ИЗ
	               |	РегистрНакопления.Продажи КАК Продажи
	               |ГДЕ
	               |	Продажи.МоделиПродукции В(&Модель)
	               |	И Продажи.МесяцПродаж В(&Месяц)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Продажи.МесяцПродаж,
	               |	Продажи.МоделиПродукции"; 
	
    Запрос.УстановитьПараметр("Модель", МассивНоменклатуры);
    Запрос.УстановитьПараметр("Месяц", МассивМесяцев);

    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();

    Запрет = Новый Соответствие;
    Пока Выборка.Следующий() Цикл
        Если Выборка.Период > Ссылка.Дата Тогда
            Ключ = Строка(Выборка.МоделиПродукции) + "|" + Формат(Выборка.МесяцПроизводства, "ДФ=yyyyMMdd");
            Запрет.Вставить(Ключ, Выборка.Период);
        КонецЕсли;
    КонецЦикла;

    Возврат Запрет;	
	
КонецФункции

#КонецОбласти

#КонецЕсли


