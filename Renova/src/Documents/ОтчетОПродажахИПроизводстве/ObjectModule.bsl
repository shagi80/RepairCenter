#Если Сервер или ТолстыйКлиентОбычноеПриложение или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПриУстановкеНовогоНомера(СтандартнаяОбработка, Префикс)
	
	Если ВидДокумента = Перечисления.ВидДокументаПродажиИПроизводство.Продажи Тогда
		Префикс= "ПРД-";
	ИначеЕсли ВидДокумента = Перечисления.ВидДокументаПродажиИПроизводство.Производство Тогда
		Префикс= "ПРЗВ-";
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
		НачалоПериода = НачалоМесяца(ТекущаяУниверсальнаяДата());
		КонецПериода = НачалоПериода;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
    	Возврат;
	КонецЕсли;
		
   	// Получаем списко видов продукции без повторений
   	ТаблицаВидовПродукции = Товары.Выгрузить( , "ВидПродукции");
   	ТаблицаВидовПродукции.Свернуть("ВидПродукции");
   	МассивВидовПродукции = ТаблицаВидовПродукции.ВыгрузитьКолонку("ВидПродукции");
   	СписокВидовПродукции = СтрСоединить(МассивВидовПродукции, ", ");

КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	ЭтоПродажи = (ВидДокумента = Перечисления.ВидДокументаПродажиИПроизводство.Продажи);	

    // Получаем соответствие запрещенных комбинаций (ключ -> дата более позднего документа)
    ЗапрещенныеКомбинации = ПолучитьЗапрещенныеКомбинации(ЭтоПродажи);

    // Начинаем формирование движений
	Если ЭтоПродажи Тогда
    	Движения.Продажи.Записывать = Истина;
	Иначе
		Движения.Производство.Записывать = Истина;
	КонецЕсли;

    КоличествоЗапрещено = 0;
    КоличествоПерезаписано = 0;

    Для Каждого ТекСтрокаТовары Из Товары Цикл

        // Пропускаем строки с незаполненными обязательными реквизитами
        Если Не ЗначениеЗаполнено(ТекСтрокаТовары.Номенклатура) Или
           Не ЗначениеЗаполнено(ТекСтрокаТовары.Количество) Тогда
            Продолжить;
        КонецЕсли;
		
		Если ЗапрещенныеКомбинации.Количество() > 0 Тогда
			// Формируем ключ для проверки (единый формат для обеих сторон)
			Ключ = СтрШаблон("%1 | %2", Строка(ТекСтрокаТовары.Номенклатура), Формат(ТекСтрокаТовары.МесяцУчета, "ДФ=yyyyMMdd"));
		КонецЕсли;
		
        // Проверяем, есть ли более поздняя запись в регистре
        Если ЗапрещенныеКомбинации.Получить(Ключ) <> Неопределено Тогда
        	
        	ТекстСообщенияПользователю = СтрШаблон("Строка по модели %1 за месяц %2 НЕ БУДЕТ ЗАПИСАНА, так как имеются более поздние данные (документ от %3).",
        								 ТекСтрокаТовары.Номенклатура, 
        								 Формат(ТекСтрокаТовары.МесяцУчета, "ДФ='MMMM yyyy';"), 
        								 Формат(ЗапрещенныеКомбинации[Ключ], "Д") );
        	
        	ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияПользователю);
        	
            КоличествоЗапрещено = КоличествоЗапрещено + 1;
            Продолжить;
        КонецЕсли;

        // Создаём движение
		Если ЭтоПродажи Тогда
			Движение = Движения.Продажи.Добавить();
			Движение.Фирма = Фирма;    
		Иначе
			Движение = Движения.Производство.Добавить();
			Движение.Фабрика = Фабрика;    
		КонецЕсли;
		Движение.Период = ТекСтрокаТовары.МесяцУчета;
		Движение.МесяцУчета = ТекСтрокаТовары.МесяцУчета; 
		Движение.ВидПродукции = ТекСтрокаТовары.ВидПродукции;
		Движение.МоделиПродукции = ТекСтрокаТовары.Номенклатура;
		Движение.Количество = ТекСтрокаТовары.Количество;

        КоличествоПерезаписано = КоличествоПерезаписано + 1;

    КонецЦикла;

    // Выводим итоговые сообщения
    Если КоличествоЗапрещено > 0 Тогда
    	ТекстСообщенияПользователю= СтрШаблон("Внимание! Было пропущено %1 строк(и) из-за наличия более поздних записей.", КоличествоЗапрещено);
        ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияПользователю);
    КонецЕсли;

    Если КоличествоПерезаписано > 0 Тогда
    	ТекстСообщенияПользователю= СтрШаблон("Записано %1 строк(и). Старые данные (если были) перезаписаны.", КоличествоПерезаписано);
        ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияПользователю);    
    Иначе
        ОбщегоНазначения.СообщитьПользователю("Нет данных для проведения документа"); 	 
		Отказ = Истина;
    КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 


#Область СлужебныеПроцедурыИФункции 

Функция ПолучитьЗапрещенныеКомбинации(ЭтоПродажи)
	
  	МассивНоменклатуры = Товары.ВыгрузитьКолонку("Номенклатура");
	МассивМесяцев = Товары.ВыгрузитьКолонку("МесяцУчета");

    // Запрос к регистру для получения максимальной даты документа по каждой комбинации
	Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Регистр.МоделиПродукции КАК МоделиПродукции,
		|	МАКСИМУМ(Регистр.Период) КАК Период,
		|	Регистр.МесяцУчета КАК МесяцУчета
		|ИЗ
		|	#ТаблицаРегистра КАК Регистр
		|ГДЕ
		|	Регистр.МоделиПродукции В(&Модель)
		|	И Регистр.МесяцУчета В(&Месяц)
		|
		|СГРУППИРОВАТЬ ПО
		|	Регистр.МоделиПродукции,
		|	Регистр.МесяцУчета";
		
	// Запрос к регистру для получения максимальной даты документа по каждой комбинации
	Если ЭтоПродажи Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ТаблицаРегистра", "РегистрНакопления.Продажи");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ТаблицаРегистра", "РегистрНакопления.Производство");
	КонецЕсли;
	
    Запрос.УстановитьПараметр("Модель", МассивНоменклатуры);
    Запрос.УстановитьПараметр("Месяц", МассивМесяцев);

    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();

    Запрет = Новый Соответствие;
    
    Пока Выборка.Следующий() Цикл

		Если Выборка.Период > Дата Тогда
			Ключ = СтрШаблон("%1 | %2", Строка(Выборка.МоделиПродукции), Формат(Выборка.МесяцУчета, "ДФ=yyyyMMdd"));
			Запрет.Вставить(Ключ, Выборка.Период);
		КонецЕсли;
		
    КонецЦикла;

    Возврат Запрет;	
	
КонецФункции

#КонецОбласти


#КонецЕсли