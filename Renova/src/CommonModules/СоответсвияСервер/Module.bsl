Функция ПолучитьСоответствиеВидовПродукцииОбщая(Массив, ВозвращатьНаименование = Ложь) Экспорт

    Соответствие = Новый Соответствие;
    
    МассивЧисел = МассивЧиселID(Массив, Соответствие);
    
    Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ
                   |	ВидыПродукции.Ссылка КАК Ссылка,
                   |	ВидыПродукции.IDСайта КАК IDСайта,
                   |	ВидыПродукции.Наименование КАК Наименование
                   |ИЗ
                   |	Справочник.ВидыПродукции КАК ВидыПродукции
                   |ГДЕ
                   |	ВидыПродукции.IDСайта В(&Массив)";
    
    Запрос.УстановитьПараметр("Массив", МассивЧисел);
    Выборка = Запрос.Выполнить().Выбрать();
	
    // Заполнение соответствия в зависимости от параметра
    Пока Выборка.Следующий() Цикл
        Если ВозвращатьНаименование Тогда
            Значение = Выборка.Наименование;
        Иначе
            Значение = Выборка.Ссылка;
        КонецЕсли;
        Соответствие.Вставить(Выборка.IDСайта, Значение);
    КонецЦикла;
    
    Возврат Соответствие;
    
КонецФункции

