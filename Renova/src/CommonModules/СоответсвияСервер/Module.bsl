Функция ПолучитьСоответствиеДокументаРемонтПоОтчету(МассивID) Экспорт
	
	Соответствие = Новый Соответствие;
	
	МассивЧисел = МассивЧиселID(МассивID, Соответствие);
	
	// Запрос для поиска кодов по IDСайта
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Ремонт.Ссылка КАК Ссылка,
	|	Ремонт.КодОтчета КАК КодОтчета
	|ИЗ
	|	Документ.Ремонт КАК Ремонт
	|ГДЕ
	|	Ремонт.КодОтчета В(&МассивID)";
	
	Запрос.УстановитьПараметр("МассивID", МассивЧисел);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	// Заполняем соответствие
	Пока Выборка.Следующий() Цикл
		Ключ = Выборка.КодОтчета;
		Значение = Выборка.Ссылка;
		
		Если Соответствие[Ключ] = Неопределено Тогда
			// Создаём массив для этого ключа
			МассивСсылок = Новый Массив;
			МассивСсылок.Добавить(Значение);
			Соответствие.Вставить(Ключ, МассивСсылок);
		Иначе
			// Добавляем в существующий массив
			МассивСсылок = Соответствие[Ключ];
			МассивСсылок.Добавить(Значение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

Функция ПолучитьПроизводитей(СимвольныйКод) Экспорт
	
	Соответствие = Новый Соответствие;
	
	// Запрос для поиска производителей
