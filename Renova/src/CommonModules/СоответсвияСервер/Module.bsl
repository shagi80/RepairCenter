Функция ПолучитьСтатусыОтчета(МассивНаименований) Экспорт
	
	Соответствие = Новый Соответствие;
	
	Соответствие.Вставить("draft", Перечисления.СтатусыОтчета.Черновик);
	Соответствие.Вставить("send", Перечисления.СтатусыОтчета.ОтправленНаПроверку);
	Соответствие.Вставить("refinement", Перечисления.СтатусыОтчета.НаДоработке);
	Соответствие.Вставить("send_again", Перечисления.СтатусыОтчета.ОтправленПовторно);
	Соответствие.Вставить("received", Перечисления.СтатусыОтчета.ПринятНаПроверку);
	Соответствие.Вставить("verified", Перечисления.СтатусыОтчета.ПроверенМенеджером);
	Соответствие.Вставить("accepted", Перечисления.СтатусыОтчета.ПринятУтвержден);
	Соответствие.Вставить("payment", Перечисления.СтатусыОтчета.Оплачен); 
	
	Возврат Соответствие;
	
КонецФункции

Функция ПолучитьСоответствиеКонтрагентов(МассивID) Экспорт
	
	Соответствие = Новый Соответствие;
	
	МассивЧисел = Новый Массив;
	Для Каждого СтрокаID Из МассивID Цикл
		Попытка
			// Пробуем преобразовать строку в число
			ЧислоЗначение = Число(СтрокаID);
			МассивЧисел.Добавить(ЧислоЗначение);
		Исключение
			// Если не удалось преобразовать, логируем ошибку
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не удалось преобразовать значение в число: " + СтрокаID;
			Сообщение.Сообщить();
		КонецПопытки;
	КонецЦикла;		
	// Если нет ID для поиска, возвращаем пустое соответствие
	Если МассивЧисел.Количество() = 0 Тогда
		Возврат Соответствие;
	КонецЕсли;
	
	// Запрос для поиска контрагентов по IDСайта
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка,
	|	Контрагенты.IDСайта КАК IDСайта
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.IDСайта В(&МассивID)";
	
	Запрос.УстановитьПараметр("МассивID", МассивЧисел);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	// Заполняем соответствие
	Пока Выборка.Следующий() Цикл
		Соответствие.Вставить(Выборка.IDСайта, Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

