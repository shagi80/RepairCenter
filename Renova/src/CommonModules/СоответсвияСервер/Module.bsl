	// Заполняем соответствие
	Пока Выборка.Следующий() Цикл
		Соответствие.Вставить(Выборка.СимвольныйКод, Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции 

Функция ПолучитьПроизводственныеСмены(КодыСмен, КодыПроизводителей) Экспорт
	
	Соответствие = Новый Соответствие;
	
	Если КодыСмен = Неопределено ИЛИ КодыСмен.Количество() = 0 
		ИЛИ КодыПроизводителей = Неопределено ИЛИ КодыПроизводителей.Количество() = 0 Тогда
		Возврат Соответствие;
	КонецЕсли;
	
	// Запрос для поиска производителей
	Запрос = Новый Запрос;
	Запрос.Текст = 
    "ВЫБРАТЬ
    |	ФабрикиИСмены.СимвольныйКод КАК СимвольныйКод,
    |	ФабрикиИСмены.Ссылка КАК Ссылка,
    |	ФабрикиИСмены.Родитель.СимвольныйКод КАК КодПроизводителя
    |ИЗ
    |	Справочник.ФабрикиИСмены КАК ФабрикиИСмены
    |ГДЕ
    |	ФабрикиИСмены.СимвольныйКод В(&КодыСмен)
    |	И НЕ ФабрикиИСмены.ЭтоГруппа
    |	И ФабрикиИСмены.Родитель.ЭтоГруппа = ИСТИНА
    |	И ФабрикиИСмены.Родитель.СимвольныйКод В(&КодыПроизводителей)";	
	
	Запрос.УстановитьПараметр("КодыСмен", КодыСмен);
    Запрос.УстановитьПараметр("КодыПроизводителей", КодыПроизводителей);
    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();
    Пока Выборка.Следующий() Цикл
        Ключ = Выборка.КодПроизводителя + "|" + Выборка.СимвольныйКод;
		Соответствие.Вставить(Ключ, Выборка.Ссылка);
	КонецЦикла;  
	
	Возврат Соответствие;
	
КонецФункции

