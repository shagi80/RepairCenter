Функция ПолучитьСоответствиеНоменклатуры(МассивЗначений, ПоИдентификаторам = Истина, ВозвращатьНаименование = Ложь) Экспорт

    Соответствие = Новый Соответствие;
    
    // Подготовка массива значений для запроса
    Если ПоИдентификаторам Тогда
        МассивДляЗапроса = МассивЧиселID(МассивЗначений, Соответствие);
    Иначе
        МассивДляЗапроса = МассивЗначений;
    КонецЕсли;
    
    Если МассивДляЗапроса.Количество() = 0 Тогда
        Возврат Соответствие;
    КонецЕсли;
    
    // Определяем поля в зависимости от режимов
    Если ПоИдентификаторам Тогда
        ПолеПоиска = "IDСайта";
        Если ВозвращатьНаименование Тогда
            ПолеЗначения = "Наименование";
        Иначе
            ПолеЗначения = "Ссылка";
        КонецЕсли;
    Иначе
        ПолеПоиска = "Наименование";
        ПолеЗначения = "Ссылка"; 
	КонецЕсли;
    
 	Запрос = Новый Запрос;
	Запрос.Текст = 
    "ВЫБРАТЬ
    |    МоделиПродукции.%1 КАК Значение,
    |    МоделиПродукции.%2 КАК Ключ
    |ИЗ
    |    Справочник.МоделиПродукции КАК МоделиПродукции
    |ГДЕ
    |    МоделиПродукции.%3 В (&МассивДляЗапроса)";
    
    ТекстЗапроса = СтрЗаменить(Запрос.Текст, "%1", ПолеЗначения);
    ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%2", ПолеПоиска);
    ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%3", ПолеПоиска);
    
    Запрос = Новый Запрос;
    Запрос.Текст = ТекстЗапроса;
    Запрос.УстановитьПараметр("МассивДляЗапроса", МассивДляЗапроса);
    
    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();
    
    Пока Выборка.Следующий() Цикл
        Соответствие.Вставить(Выборка.Ключ, Выборка.Значение);
    КонецЦикла;
    
    Возврат Соответствие; 
КонецФункции

Функция ПолучитьСоответствиеГруппКодовНеисправностей(МассивНаименований) Экспорт
	
	Соответствие = Новый Соответствие;
	
	// Запрос для поиска кодов по IDСайта
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КодыНеисправностей.Ссылка КАК Ссылка,
	|	КодыНеисправностей.IDСайта КАК IDСайта,
	|	КодыНеисправностей.Наименование КАК Наименование
	|ИЗ
	|	Справочник.КодыНеисправностей КАК КодыНеисправностей
	|ГДЕ
	|	КодыНеисправностей.IDСайта В(&МассивНаименований)";
	
	Запрос.УстановитьПараметр("МассивНаименований", МассивНаименований);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	// Заполняем соответствие
	Пока Выборка.Следующий() Цикл
		Соответствие.Вставить(Выборка.Наименование, Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

// Общая функция для текущего модуля
Функция МассивЧиселID(МассивID, Соответствие)
	
	МассивЧисел = Новый Массив;
	
	Для Каждого СтрокаID Из МассивID Цикл
		Попытка
			// Пробуем преобразовать строку в число
			ЧислоЗначение = Число(СтрокаID);
			МассивЧисел.Добавить(ЧислоЗначение);
		Исключение
			// Если не удалось преобразовать, логируем ошибку
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не удалось преобразовать значение в число: " + СтрокаID;
			Сообщение.Сообщить();
		КонецПопытки;
	КонецЦикла;		
	// Если нет ID для поиска, возвращаем пустое соответствие
	Если МассивЧисел.Количество() = 0 Тогда
		Возврат Соответствие;
	Иначе
		Возврат МассивЧисел;
	КонецЕсли;
	
КонецФункции

