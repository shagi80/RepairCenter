
Функция ПолучитьСоответствиеДокументаАкт_НРП(МассивID) Экспорт
	
	Соответствие = Новый Соответствие;
	
	МассивЧисел = МассивЧиселID(МассивID, Соответствие);
	
	// Запрос для поиска кодов по IDСайта
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	АктНРП.Ссылка КАК Ссылка,
	|	АктНРП.IDСайта КАК IDСайта
	|ИЗ
	|	Документ.АктНРП КАК АктНРП
	|ГДЕ
	|	АктНРП.IDСайта В (&МассивID)";
	
	Запрос.УстановитьПараметр("МассивID", МассивЧисел);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	// Заполняем соответствие
	Пока Выборка.Следующий() Цикл
		Соответствие.Вставить(Выборка.IDСайта, Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Соответствие;
	
КонецФункции

