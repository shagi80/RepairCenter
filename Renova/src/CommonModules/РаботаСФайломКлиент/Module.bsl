#Область СлужебныеПроцедурыИФункции

// Выполняет асинхронный выбор файла через диалог открытия.
// 
// Параметры:
//   Параметры - Структура, Неопределено - параметры диалога. Может содержать ключи:
//       * Фильтр - Строка - фильтр файлов (по умолчанию "CSV|*.CSV").
//       * Заголовок - Строка - заголовок окна диалога (по умолчанию "Выберите файл CSV для загрузки").
//       * ИдентификаторФормы - УникальныйИдентификатор, Неопределено - идентификатор формы-владельца
//         для корректного позиционирования диалога (если не указан, создаётся новый).
// 
// Возвращаемое значение:
//   Структура - результат выбора файла. Содержит поля:
//       * ФайлВыбран - Булево - Истина, если файл успешно выбран, Ложь в случае отмены или ошибки.
//       * ПутьКФайлу - Строка - полный путь к выбранному файлу (заполняется, если ФайлВыбран = Истина).
//       * ТекстОшибки - Строка - описание ошибки или сообщение об отмене (если файл не выбран).
//
Асинх Функция ВыбратьФайл(Параметры = Неопределено) Экспорт
    
	Если Параметры = Неопределено Тогда
		Параметры = Новый Структура;
	КонецЕсли;
	
	// Значения по умолчанию
	Фильтр = ?(Параметры.Свойство("Фильтр"), Параметры.Фильтр, "CSV|*.CSV");
	Заголовок = ?(Параметры.Свойство("Заголовок"), Параметры.Заголовок, "Выберите файл CSV для загрузки");
	ИдентификаторФормы = ?(Параметры.Свойство("ИдентификаторФормы"), Параметры.ИдентификаторФормы, Неопределено);
	
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогОткрытияФайла.ПолноеИмяФайла = "";
	ДиалогОткрытияФайла.Фильтр = Фильтр;
	ДиалогОткрытияФайла.Заголовок = Заголовок;
	
	Результат = Новый Структура("ФайлВыбран, ПутьКФайлу, ТекстОшибки", Ложь, "", "", "");
	
	РезультатВыбора = Ждать ДиалогОткрытияФайла.ВыбратьАсинх();
	
	Если РезультатВыбора = Неопределено Тогда
		// Пользователь отменил выбор
		Результат.ТекстОшибки = НСтр("ru = 'Файл не выбран'");
		Возврат Результат;
	КонецЕсли;
	
	Результат.ПутьКФайлу = ДиалогОткрытияФайла.ПолноеИмяФайла;
	
	Если ИдентификаторФормы = Неопределено Тогда
		// Если идентификатор не передан, создаём новый (доступен только в рамках текущего сеанса)
		ИдентификаторФормы = Новый УникальныйИдентификатор;
	КонецЕсли;

	Результат.ФайлВыбран = Истина;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти


