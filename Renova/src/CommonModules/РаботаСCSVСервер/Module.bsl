 
#Область СлужебныеПроцедурыИФункции 

Функция ПрочитатьФайлCSV(ПутьФайла) Экспорт
	    
    ЗагружаемыйФайл = Новый ТекстовыйДокумент; 
	Кодировка = КодировкаТекста.UTF8;
    ЗагружаемыйФайл.Прочитать(ПутьФайла, Кодировка);	
	Разделитель = "|";
	ТаблицаЗначений = ЗагрузитьФайлCSVВТабЗнач(ЗагружаемыйФайл, Разделитель);
	
	Возврат ТаблицаЗначений;
	
КонецФункции

Функция ЗагрузитьФайлCSVВТабЗнач(ФайлCSV, Разделитель) Экспорт
	
	ТабЗнач = Новый ТаблицаЗначений;
	
	// Обрабатываем весь файл как одну строку, чтобы корректно обработать переносы строк внутри кавычек
	ТекстФайла = ФайлCSV.ПолучитьТекст();
			
	// Разбираем CSV
	МассивСтрок = РазобратьCSV(ТекстФайла, Разделитель);
	
	Если МассивСтрок.Количество() = 0 Тогда
		Возврат ТабЗнач;
	КонецЕсли;
	
	// 1. Обрабатываем заголовок (первую строку)
	МассивЗаголовков = МассивСтрок[0];
	
	Для Каждого Заголовок Из МассивЗаголовков Цикл
		// Убираем пробелы и кавычки в имени колонки ТЗ
		ИмяКолонки = СтрЗаменить(СокрЛП(СтрЗаменить(Заголовок, """", "")), " ", "");
		Если ИмяКолонки = "" Тогда
			ИмяКолонки = "Колонка" + ТабЗнач.Колонки.Количество();
		КонецЕсли;
		ТабЗнач.Колонки.Добавить(ИмяКолонки);
	КонецЦикла;
	
	// 2. Обрабатываем строки с данными 
	Для ИндексСтроки = 1 По МассивСтрок.Количество() - 1 Цикл
		МассивДанных = МассивСтрок[ИндексСтроки];
		
		// Пропускаем пустые строки
		Если МассивДанных.Количество() = 1 И МассивДанных[0] = "" Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрокаТЗ = ТабЗнач.Добавить();
		Для Индекс = 0 По МассивДанных.Количество() - 1 Цикл
			Если Индекс >= ТабЗнач.Колонки.Количество() Тогда
				Прервать;
			КонецЕсли;
			
			ИмяКолонки = ТабЗнач.Колонки[Индекс].Имя;
			Значение = МассивДанных[Индекс];
			
			// Убираем обрамляющие кавычки, если они есть
			Если СтрДлина(Значение) >= 2 И Сред(Значение, 1, 1) = """" И Сред(Значение, СтрДлина(Значение), 1) = """" Тогда
				Значение = Сред(Значение, 2, СтрДлина(Значение) - 2);
			КонецЕсли;
			
			// Заменяем удвоенные кавычки на одинарные
			Значение = СтрЗаменить(Значение, """""", """");
			
			НоваяСтрокаТЗ[ИмяКолонки] = Значение;
		КонецЦикла;
	КонецЦикла;
    
    Возврат ТабЗнач;

КонецФункции 

Функция РазобратьCSV(СтрокаCSV, Разделитель)
		
		Результат = Новый Массив;
		ТекущаяСтрока = Новый Массив;
		ТекущееПоле = "";
		ВКавычках = Ложь;
		Строка = 1;
		
		Пока Строка <= СтрДлина(СтрокаCSV) Цикл
			Символ = Сред(СтрокаCSV, Строка, 1);
			СледующийСимвол = "";
			Если Строка < СтрДлина(СтрокаCSV) Тогда
				СледующийСимвол = Сред(СтрокаCSV, Строка + 1, 1);
			КонецЕсли;
			
			Если Символ = """" Тогда
				Если ВКавычках Тогда
					Если СледующийСимвол = """" Тогда
						// Удвоенная кавычка - экранирование
						ТекущееПоле = ТекущееПоле + """";
						Строка = Строка + 1;
					Иначе
						ВКавычках = Ложь;
					КонецЕсли;
				Иначе
					ВКавычках = Истина;
				КонецЕсли;
			ИначеЕсли Символ = Разделитель И Не ВКавычках Тогда
				// Конец поля
				ТекущаяСтрока.Добавить(ТекущееПоле);
				ТекущееПоле = "";
			ИначеЕсли (Символ = Символы.ПС ИЛИ Символ = Символы.ВК) И Не ВКавычках Тогда
				// Конец строки (только если не внутри кавычек)
				ТекущаяСтрока.Добавить(ТекущееПоле);
				Результат.Добавить(ТекущаяСтрока);
				ТекущаяСтрока = Новый Массив;
				ТекущееПоле = "";
				
				// Пропускаем возможный парный символ переноса строки
				Если Символ = Символы.ВК И СледующийСимвол = Символы.ПС Тогда
					Строка = Строка + 1;
				КонецЕсли;
			Иначе
				ТекущееПоле = ТекущееПоле + Символ;
			КонецЕсли;
			
			Строка = Строка + 1;
		КонецЦикла;
		
		// Добавляем последнее поле и строку, если они есть
		Если ТекущееПоле <> "" ИЛИ ТекущаяСтрока.Количество() > 0 Тогда
			ТекущаяСтрока.Добавить(ТекущееПоле);
			Результат.Добавить(ТекущаяСтрока);
		КонецЕсли;
		
		Возврат Результат;
		
КонецФункции

