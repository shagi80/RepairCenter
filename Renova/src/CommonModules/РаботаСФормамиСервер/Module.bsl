
Процедура ОбновитьДинамическуюТаблицу(Форма, ИмяРеквизитаТаблицы, ИмяЭлементаТаблицы, ИмяРеквизитаСообщения, НоваяТаблица) Экспорт

    // Проверка типа
    Если ТипЗнч(НоваяТаблица) <> Тип("ТаблицаЗначений") Тогда
        Сообщить("Ошибка: в процедуру передана не таблица значений!");
        НоваяТаблица = Новый ТаблицаЗначений;
    КонецЕсли;

    // Получаем текущую таблицу из реквизита формы
    ТекущаяТаблица = Форма.РеквизитФормыВЗначение(ИмяРеквизитаТаблицы);

    // Удаление старых колонок (реквизитов)
    МассивУдаляемыхРеквизитов = Новый Массив;
    Для Каждого Колонка Из ТекущаяТаблица.Колонки Цикл
        МассивУдаляемыхРеквизитов.Добавить(ИмяРеквизитаТаблицы + "." + Колонка.Имя);
    КонецЦикла;
    Если МассивУдаляемыхРеквизитов.Количество() > 0 Тогда
        Форма.ИзменитьРеквизиты(, МассивУдаляемыхРеквизитов);
    КонецЕсли;

    // Удаление старого элемента таблицы (если есть)
    ЭлементТаблица = Форма.Элементы.Найти(ИмяЭлементаТаблицы);
    Если ЭлементТаблица <> Неопределено Тогда
        Форма.Элементы.Удалить(ЭлементТаблица);
    КонецЕсли;

    // Создание нового элемента таблицы
    ЭлементТаблица = Форма.Элементы.Добавить(ИмяЭлементаТаблицы, Тип("ТаблицаФормы"));
    ЭлементТаблица.ПутьКДанным = ИмяРеквизитаТаблицы;
    ЭлементТаблица.Отображение = ОтображениеТаблицы.Список;

    // Создание новых реквизитов для колонок
    МассивНовыхРеквизитов = Новый Массив;
    Для Каждого Колонка Из НоваяТаблица.Колонки Цикл
        МассивТипов = Новый Массив;
        МассивТипов.Добавить(Колонка.ТипЗначения);
        НоваяКолонка = Новый РеквизитФормы(Колонка.Имя, Новый ОписаниеТипов(МассивТипов), ИмяРеквизитаТаблицы); 
        НоваяКолонка.Заголовок = Колонка.Имя;
        МассивНовыхРеквизитов.Добавить(НоваяКолонка);
    КонецЦикла;
    Форма.ИзменитьРеквизиты(МассивНовыхРеквизитов);

    // Помещаем данные
    Форма.ЗначениеВРеквизитФормы(НоваяТаблица, ИмяРеквизитаТаблицы);

    // Создание элементов полей для колонок
    ЭлементТЗ = Форма.Элементы[ИмяЭлементаТаблицы];
    Для Каждого Колонка Из НоваяТаблица.Колонки Цикл
        НовыйЭлементФормы = Форма.Элементы.Добавить(Колонка.Имя, Тип("ПолеФормы"), ЭлементТЗ);
        НовыйЭлементФормы.Вид = ВидПоляФормы.ПолеВвода;
        НовыйЭлементФормы.ПутьКДанным = ИмяРеквизитаТаблицы + "." + Колонка.Имя;
    КонецЦикла;

    // Обновление реквизита с сообщением (если имя указано)
    Если ЗначениеЗаполнено(ИмяРеквизитаСообщения) Тогда
        Форма[ИмяРеквизитаСообщения] = "Количество строк в таблице: " + Строка(НоваяТаблица.Количество());
    КонецЕсли;

КонецПроцедуры