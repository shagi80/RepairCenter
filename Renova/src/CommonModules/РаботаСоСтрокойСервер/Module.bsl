
#Область СлужебныеПроцедурыИФункции

Функция БезопасноеПреобразованиеВЧисло(Значение) Экспорт
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;
	
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		ЧистаяСтрока = СокрЛП(Значение);
		Если ПустаяСтрока(ЧистаяСтрока) Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Попытка
			Возврат Число(ЧистаяСтрока);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецЕсли;
	
	Возврат Неопределено; 
	
КонецФункции

Функция ПреобразоватьСтрокуВДату(СтрокаДляПреобразования) Экспорт
	
	Попытка
		// Разбиваем строку
		Части = СтрРазделить(СтрокаДляПреобразования, "-");
		
		Если Части.Количество() < 3 Тогда
			ВызватьИсключение "Неверный формат даты";
		КонецЕсли;
		
		Год  = Число(Части[0]);
		Месяц = Число(Части[1]);
		День  = Число(Части[2]);
		
		// Проверяем диапазоны
		Если Год < 1900 Или Год > 2100 Тогда
			ВызватьИсключение "Год вне допустимого диапазона";
		КонецЕсли;
		
		Если Месяц < 1 Или Месяц > 12 Тогда
			ВызватьИсключение "Месяц должен быть от 1 до 12";
		КонецЕсли;
		
		Если День < 1 Или День > 31 Тогда
			ВызватьИсключение "День должен быть от 1 до 31";
		КонецЕсли;
		Дата = Дата(Год, Месяц, День); 
		// Создаем дату
		Возврат Дата;
		
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Функция МесяцГодИзДаты(ДатаДляФорматирования) Экспорт
    
    Возврат Формат(ДатаДляФорматирования, "ДФ='ММММ yyyy'"); 
	
КонецФункции

Функция СтрокаСодержитБукву(ПроверяемаяСтрока) Экспорт

    Для Номер = 1 По СтрДлина(ПроверяемаяСтрока) Цикл
        Символ = Сред(ПроверяемаяСтрока, Номер, 1);
        КодСимвола = КодСимвола(Символ);
        
        // Латиница: A-Z (65-90), a-z (97-122)
        // Кириллица: А-я (1040-1103), Ё (1025), ё (1105)
        Если (КодСимвола >= 65 И КодСимвола <= 90)
            Или (КодСимвола >= 97 И КодСимвола <= 122)
            Или (КодСимвола >= 1040 И КодСимвола <= 1103)
            Или (КодСимвола = 1025 Или КодСимвола = 1105) Тогда
            Возврат Истина;
        КонецЕсли;
    КонецЦикла;
    
    Возврат Ложь;
    
КонецФункции

Функция ПреобразоватьДатуИзДвузначногоГода(СтрокаДаты) Экспорт
	
    Части = СтрРазделить(СтрокаДаты, ".", Ложь);
    Если Части.Количество() <> 3 Тогда
        ВызватьИсключение СтрШаблон(НСтр("ru = 'Неверный формат даты: %1'"), СтрокаДаты);
    КонецЕсли;
    День   = Число(Части[0]);
    Месяц  = Число(Части[1]);
    Год    = Число(Части[2]);
    // Интерпретация двухзначного года: 00-29 -> 2000-2029, 30-99 -> 1930-1999 (стандарт 1С)
    ПолныйГод = Год;
    Если Год < 30 Тогда
        ПолныйГод = 2000 + Год;
    ИначеЕсли Год < 100 Тогда
        ПолныйГод = 1900 + Год;
    КонецЕсли;
    Возврат Дата(ПолныйГод, Месяц, День);  
	
КонецФункции  

Функция ПолучитьМассивДатМесяцев(ДатаНачала, ДатаОкончания) Экспорт

	Месяцы = Новый Массив;
	ТекДата = ДатаНачала;
	Пока ТекДата <= ДатаОкончания Цикл
		Месяцы.Добавить(ТекДата);
		ТекДата = ДобавитьМесяц(ТекДата, 1);
	КонецЦикла;
	Возврат Месяцы;

КонецФункции

