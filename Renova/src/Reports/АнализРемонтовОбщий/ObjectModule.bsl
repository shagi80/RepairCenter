КонецПроцедуры

Процедура НастройкаКруговойДиаграммы()
	
	Для каждого ЭлементНастройки Из КомпоновщикНастроек.Настройки.Структура Цикл
		
		Если ТипЗнч(ЭлементНастройки) = Тип("ДиаграммаКомпоновкиДанных") Тогда
			
			ЭлементНастройки.Точки.Очистить();
			
			Если ТипЗнч(ЭлементНастройки.Серии) = Тип("КоллекцияЭлементовСтруктурыДиаграммыКомпоновкиДанных") Тогда
				НовыйЭлементСерия = ЭлементНастройки.Серии.Добавить();
				НовыйЭлементСерия.Использование = Истина;
				НовыйЭлементПолеСерия = НовыйЭлементСерия.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
				НовыйЭлементПолеСерия.Поле = Новый ПолеКомпоновкиДанных("ВидПродукции");
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура НастройкаГистограммы()
	
	Для каждого ЭлементНастройки Из КомпоновщикНастроек.Настройки.Структура Цикл
		
		Если ТипЗнч(ЭлементНастройки) = Тип("ДиаграммаКомпоновкиДанных") Тогда
			
			ЭлементНастройки.Серии.Очистить();
			ЭлементНастройки.Точки.Очистить();
			
			Если ТипЗнч(ЭлементНастройки.Серии) = Тип("КоллекцияЭлементовСтруктурыДиаграммыКомпоновкиДанных") Тогда
				НовыйЭлементСерия = ЭлементНастройки.Серии.Добавить();
				НовыйЭлементСерия.Использование = Истина;
				НовыйЭлементПолеСерия = НовыйЭлементСерия.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
				НовыйЭлементПолеСерия.Поле = Новый ПолеКомпоновкиДанных("Год");
			КонецЕсли;
			
			Если ТипЗнч(ЭлементНастройки.Точки) = Тип("КоллекцияЭлементовСтруктурыДиаграммыКомпоновкиДанных") Тогда
				НовыйЭлементТочка = ЭлементНастройки.Точки.Добавить();
				НовыйЭлементТочка.Использование = Истина;
				НовыйЭлементПолеТочка = НовыйЭлементТочка.ПоляГруппировки.Элементы.Добавить(Тип("ПолеГруппировкиКомпоновкиДанных"));
				НовыйЭлементПолеТочка.Поле = Новый ПолеКомпоновкиДанных("ВидПродукции");
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Функция ПолучитьДиаграммуИзНастроекОтчета()
	
	Для каждого ЭлементНастройки Из КомпоновщикНастроек.Настройки.Структура Цикл
		
		Если ТипЗнч(ЭлементНастройки) = Тип("ДиаграммаКомпоновкиДанных") Тогда
			Возврат ЭлементНастройки;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

