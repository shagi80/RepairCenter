
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка) Экспорт
	
	ДанныеОтчетаПериод = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы;
	ДатаНачала = ДанныеОтчетаПериод[0].Значение.ДатаНачала;
	ДатаОкончания = ДанныеОтчетаПериод[0].Значение.ДатаОкончания;
	
	ГодНачала = Год(ДатаНачала);
	ГодОкончния = Год(ДатаОкончания);
	
	РазницаДней = (КонецДня(ДатаОкончания) - НачалоДня(ДатаНачала)) / 86400;
	КоличествоЛетРасчет = РазницаДней / 365;
	КоличествоЛетРасчетВСКГод = РазницаДней / 366;
	
	Если КоличествоЛетРасчет <= 1 Тогда
		КоличествоЛет = 1;
	ИначеЕсли Окр(КоличествоЛетРасчет, 2, РежимОкругления.Окр15как20) > Цел(КоличествоЛетРасчет) Тогда
		КоличествоЛет = Цел(КоличествоЛетРасчет) + 1;
	Иначе
		КоличествоЛет = Цел(КоличествоЛетРасчет);
	КонецЕсли;
	
	ГодыОтчета = Новый Соответствие;
	ГодыОтчета.Вставить(1, ГодНачала);
	
	Для Сч = 1 По КоличествоЛет - 1 Цикл
		ОчереднойГод = ГодНачала + Сч;
		ГодыОтчета.Вставить(Сч + 1, Число(ОчереднойГод));
	КонецЦикла;
	
	Если КоличествоЛет > 1 Тогда
		КомпоновщикНастроек.Настройки.ПараметрыВывода.УстановитьЗначениеПараметра("ТипДиаграммы", ТипДиаграммы.ГистограммаОбъемная);
		НастройкаГистограммы();
	КонецЕсли;
	
	Если КоличествоЛет <= 1 Тогда
		КомпоновщикНастроек.Настройки.ПараметрыВывода.УстановитьЗначениеПараметра("ТипДиаграммы", ТипДиаграммы.КруговаяОбъемная);
		НастройкаКруговойДиаграммы();
	КонецЕсли;
